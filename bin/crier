#!/usr/bin/env bash
# The TTS daemon, and everything you'd want to tweak by ear.
# The daemon keeps the model resident, so a hook only ever pays for synthesis.
#
#   crier setup                                  re-ask language / agent / name
#   crier install [claude|codex|gemini|cursor]   wire up an agent
#   crier uninstall [agent]                      unwire it
#   crier start | stop | restart | status
#   crier voices              hear all 10 voices
#   crier voice M3            F1–F5 (female) · M1–M5 (male)
#   crier tone playful        plain | friendly | playful
#   crier lang ja             ko | en | ja
#   crier name "Jaeho"        used now and then, not every time ("" turns it off)
#   crier chimes [soft|bell]  hear them, or switch (soft is gentler)
#   crier demo                hear every event
#   crier prompt install      let the agent write its own spoken line
#   crier mute / unmute       going into a meeting
#   crier say "anything"      one-off
set -u

# bootstrap.sh symlinks this onto your PATH, so BASH_SOURCE is the symlink, not the
# script. Follow it to its real home before working out where the repo lives.
SELF="${BASH_SOURCE[0]}"
while [ -L "$SELF" ]; do
  LINK_DIR="$(cd -P "$(dirname "$SELF")" && pwd)"
  SELF="$(readlink "$SELF")"
  case "$SELF" in /*) ;; *) SELF="$LINK_DIR/$SELF" ;; esac
done
ROOT="$(cd -P "$(dirname "$SELF")/.." && pwd)"
PY="$ROOT/.venv/bin/python"
SUPERTONIC="$ROOT/.venv/bin/supertonic"
LOG="$ROOT/.venv/supertonic.log"
CFG="$ROOT/config.json"

cfg()  { "$PY" -c "import json;print(json.load(open('$CFG')).get('$1',''))"; }
PORT="$(cfg port)"
up()   { nc -z 127.0.0.1 "$PORT" 2>/dev/null; }

start() {
  "$PY" "$ROOT/bin/earcons.py" >/dev/null 2>&1     # generate chimes if missing
  up && return 0
  "$SUPERTONIC" serve --port "$PORT" --log-level warning >"$LOG" 2>&1 &
  disown
  for _ in $(seq 1 60); do
    up && { echo "up — 127.0.0.1:$PORT (voice=$(cfg voice))"; return 0; }
    sleep 0.5
  done
  echo "failed to start. log: $LOG" >&2; tail -5 "$LOG" >&2; return 1
}

# say <chime> <sentence> — takes the exact path a hook takes
say() {
  start >/dev/null || exit 1
  printf '%s\n%s' "$1" "$2" | AGENT_VOICE_CHILD=1 "$PY" "$ROOT/bin/announce.py"
}

set_key() {
  "$PY" - "$1" "$2" "$CFG" <<'PY'
import json, pathlib, sys
key, value, path = sys.argv[1], sys.argv[2], pathlib.Path(sys.argv[3])
cfg = json.loads(path.read_text())
if key == "name_chance":
    cfg[key] = float(value)
elif value in ("true", "false"):
    cfg[key] = value == "true"
else:
    cfg[key] = value
path.write_text(json.dumps(cfg, indent=2, ensure_ascii=False) + "\n")
print(f"{key} = {cfg[key]!r}")
PY
}

set_earcon_style() {
  "$PY" - "$1" "$CFG" <<'PY'
import json, pathlib, sys
style, path = sys.argv[1], pathlib.Path(sys.argv[2])
cfg = json.loads(path.read_text())
cfg.setdefault("earcons", {})["style"] = style
path.write_text(json.dumps(cfg, indent=2, ensure_ascii=False) + "\n")
print(f"chimes = {style}")
PY
}

# sample <key> — a random line of the current locale/tone, for previews
sample() {
  "$PY" - "$ROOT" "$1" <<'PY'
import json, pathlib, random, sys
root, key = pathlib.Path(sys.argv[1]), sys.argv[2]
cfg = json.loads((root / "config.json").read_text())
loc = json.loads((root / "locales.json").read_text())[cfg["lang"]]
if key == "example":
    print(loc["prompt"]["example"])
elif key == "error":
    print(random.choice(loc[cfg["tone"]]["error"]).format(what=loc["errors"]["rate_limit"]))
else:
    print(random.choice(loc[cfg["tone"]][key]).format(what="rm"))
PY
}

preview_voice() {
  "$PY" - "$1" "$PORT" "$ROOT" <<'PY'
import json, pathlib, subprocess, sys, tempfile, urllib.request
voice, port, root = sys.argv[1], sys.argv[2], pathlib.Path(sys.argv[3])
cfg = json.loads((root / "config.json").read_text())
loc = json.loads((root / "locales.json").read_text())[cfg["lang"]]
body = json.dumps({"text": loc["prompt"]["example"], "voice": voice,
                   "lang": cfg["lang"], "response_format": "wav"}).encode()
req = urllib.request.Request(f"http://127.0.0.1:{port}/v1/tts", data=body,
                             headers={"Content-Type": "application/json"})
with urllib.request.urlopen(req, timeout=30) as r, \
        tempfile.NamedTemporaryFile(suffix=".wav") as f:
    f.write(r.read()); f.flush()
    subprocess.run(["afplay" if sys.platform == "darwin" else "aplay", f.name])
PY
}

case "${1:-status}" in
  start)   start ;;
  stop)    pkill -f "supertonic serve --port $PORT" 2>/dev/null && echo "stopped" || echo "not running" ;;
  restart) pkill -f "supertonic serve --port $PORT" 2>/dev/null; sleep 1; start ;;
  status)
    up && echo "running — voice=$(cfg voice) · lang=$(cfg lang) · tone=$(cfg tone) · name=$(cfg call_name)$([ "$(cfg muted)" = "True" ] && echo " · MUTED")" \
       || echo "stopped" ;;

  setup)
    A="$("$PY" "$ROOT/bin/setup.py" "${@:2}" | tail -1)"
    "$PY" "$ROOT/bin/wire.py" "$A" || exit 1
    "$PY" "$ROOT/bin/prompt.py" install --agent "$A"
    start >/dev/null
    say done "$(sample example)"
    ;;

  install)
    A="${2:-claude}"
    "$PY" "$ROOT/bin/wire.py" "$A" || exit 1
    "$PY" "$ROOT/bin/prompt.py" install --agent "$A"
    start
    echo "Restart your agent session. Then try:  crier demo"
    ;;

  uninstall)
    A="${2:-claude}"
    "$PY" "$ROOT/bin/wire.py" "$A" --remove || exit 1
    "$PY" "$ROOT/bin/prompt.py" remove --agent "$A" || true
    pkill -f "supertonic serve --port $PORT" 2>/dev/null || true
    echo "Unwired. The repo is still at $ROOT — delete it to finish."
    ;;

  update)
    git -C "$ROOT" pull --ff-only && "$ROOT/install.sh" --no-hooks
    ;;

  say)     say done "${2:-hello}" ;;
  prompt)  "$PY" "$ROOT/bin/prompt.py" "${@:2}" ;;

  # Going into a meeting. The daemon stays warm so unmuting is instant.
  mute)    set_key muted true  >/dev/null; pkill -x afplay 2>/dev/null; echo "muted" ;;
  unmute)  set_key muted false >/dev/null; echo "unmuted"; say done "$(sample example)" ;;

  chimes)
    if [ $# -ge 2 ]; then
      case "$2" in
        soft|bell) "$PY" "$ROOT/bin/earcons.py" --style "$2" --force >/dev/null
                   set_earcon_style "$2" ;;
        *) echo "soft | bell" >&2; exit 2 ;;
      esac
    fi
    "$PY" "$ROOT/bin/earcons.py" --play
    ;;

  voices)
    start >/dev/null || exit 1
    echo "current: $(cfg voice)"
    for v in F1 F2 F3 F4 F5 M1 M2 M3 M4 M5; do
      printf '  %s\n' "$v"
      preview_voice "$v"
    done
    echo
    echo "pick one:  crier voice F3"
    ;;

  voice)
    [ $# -ge 2 ] || { echo "usage: crier voice F1|…|F5|M1|…|M5" >&2; exit 2; }
    case "$2" in F[1-5]|M[1-5]) ;; *) echo "F1–F5 or M1–M5" >&2; exit 2 ;; esac
    set_key voice "$2"
    say done "$(sample example)"
    ;;

  tone)
    [ $# -ge 2 ] || { echo "usage: crier tone plain|friendly|playful" >&2; exit 2; }
    case "$2" in plain|friendly|playful) ;; *) echo "plain · friendly · playful" >&2; exit 2 ;; esac
    set_key tone "$2"
    "$PY" "$ROOT/bin/prompt.py" install >/dev/null   # the tone lives in the prompt too
    say ask "$(sample permission_bash)"
    ;;

  lang)
    [ $# -ge 2 ] || { echo "usage: crier lang ko|en|ja" >&2; exit 2; }
    case "$2" in ko|en|ja) ;; *) echo "ko · en · ja" >&2; exit 2 ;; esac
    set_key lang "$2"
    "$PY" "$ROOT/bin/prompt.py" install >/dev/null
    say done "$(sample example)"
    ;;

  name)
    [ $# -ge 2 ] || { echo 'usage: crier name "Jaeho"    ("" turns it off)' >&2; exit 2; }
    set_key call_name "$2"
    [ -n "$2" ] && say done "$2, $(sample example)"
    ;;

  demo)
    start >/dev/null || exit 1
    say ask   "$(sample permission_bash)" ; sleep 0.5
    say error "$(sample error)"           ; sleep 0.5
    say idle  "$(sample idle)"            ; sleep 0.5
    say done  "$(sample example)"
    ;;

  *) echo 'usage: crier {install [agent]|uninstall|update|start|stop|restart|status|voices|voice F3|tone playful|lang ja|name "X"|chimes|demo|prompt install}' >&2
     exit 2 ;;
esac
